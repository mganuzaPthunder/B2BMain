"compilerOptions": {
  "target": "ESNext",
  "lib": ["DOM", "DOM.Iterable", "ES2020"],
  "types": ["vite/client", "vitest/globals"],
  "allowJs": true,
  "skipLibCheck": true,
  "esModuleInterop": true,
  "module": "ESNext",
  "jsx": "react-jsx",
  "resolveJsonModule": true,
  "isolatedModules": true,
  "noEmit": true,
  "strict": true,
  "forceConsistentCasingInFileNames": true,
  "moduleResolution": "bundler",
  "baseUrl": ".",
  "paths": {
    "@/*": ["src/*"],
    "@/lib/*": ["src/lib/*"]
  }
}